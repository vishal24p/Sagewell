# Environment and secrets
.env
.env.*
!.env.example
.venv/
venv/
ENV/

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage/

# Build artifacts
dist/
build/
*.egg-info/

# Logs and runtime files
logs/
*.log
*.pid

# Databases and local state
*.sqlite
*.sqlite3

# CodeGraph local index
.codegraph/

# PDFs are ignored by default; already tracked PDFs remain tracked.
*.pdf

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editors and IDEs
.idea/
.vscode/
*.swp
*.swo
*~

# Real-data corpora
# The `en/` and `website-main/` trees are real data, not code.
# They are intentionally NOT pushed to the repository; the
# M15 release-gate test reads them locally through the
# REAL_CORPUS_DIR env var (default: <repo>/en).
#
# Adding more corpora here: keep the rule above this comment.
en/
website-main/
